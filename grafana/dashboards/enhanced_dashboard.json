    "panels": [
        {
            "collapsed": false,
            "gridPos": {
                "h": 1,
                "w": 24,
                "x": 0,
                "y": 0
            },
            "id": 100,
            "panels": [],
            "title": "Anomaly Detection (Z-Score > 3)",
            "type": "row"
        },
        {
            "datasource": {
                "type": "prometheus",
                "uid": "Hawk-Eye-Prometheus"
            },
            "fieldConfig": {
                "defaults": {
                    "color": {
                        "mode": "palette-classic"
                    },
                    "custom": {
                        "drawStyle": "points",
                        "pointSize": 10
                    }
                },
                "overrides": []
            },
            "gridPos": {
                "h": 6,
                "w": 24,
                "x": 0,
                "y": 1
            },
            "id": 101,
            "targets": [
                {
                    "expr": "(hawkeye_latency_seconds - avg_over_time(hawkeye_latency_seconds[1h])) / stddev_over_time(hawkeye_latency_seconds[1h]) > 3",
                    "legendFormat": "LATENCY SPIKE: {{target}}",
                    "refId": "A"
                },
                {
                    "expr": "(hawkeye_dns_advanced_duration_seconds - avg_over_time(hawkeye_dns_advanced_duration_seconds[1h])) / stddev_over_time(hawkeye_dns_advanced_duration_seconds[1h]) > 3",
                    "legendFormat": "DNS SPIKE: {{target}}",
                    "refId": "B"
                }
            ],
            "title": "Detected Performance Spikes",
            "type": "timeseries"
        },
        {
            "collapsed": false,
            "gridPos": {
                "h": 1,
                "w": 24,
                "x": 0,
                "y": 0
            },
            "id": 1,
            "panels": [],
            "title": "Status Summary",
            "type": "row"
        },
        {
            "datasource": {
                "type": "prometheus",
                "uid": "Hawk-Eye-Prometheus"
            },
            "fieldConfig": {
                "defaults": {
                    "color": {
                        "mode": "thresholds"
                    },
                    "mappings": [
                        {
                            "options": {
                                "0": {
                                    "color": "red",
                                    "index": 1,
                                    "text": "DOWN"
                                },
                                "1": {
                                    "color": "green",
                                    "index": 0,
                                    "text": "UP"
                                }
                            },
                            "type": "value"
                        }
                    ],
                    "thresholds": {
                        "mode": "absolute",
                        "steps": [
                            {
                                "color": "red",
                                "value": null
                            },
                            {
                                "color": "green",
                                "value": 1
                            }
                        ]
                    }
                },
                "overrides": []
            },
            "gridPos": {
                "h": 6,
                "w": 12,
                "x": 0,
                "y": 1
            },
            "id": 2,
            "options": {
                "mergeValues": true,
                "showValue": "never",
                "tooltip": {
                    "mode": "single",
                    "sort": "none"
                }
            },
            "targets": [
                {
                    "expr": "hawkeye_health_up",
                    "legendFormat": "Health: {{target}}",
                    "refId": "A"
                }
            ],
            "title": "HTTP Health Status",
            "type": "state-timeline"
        },
